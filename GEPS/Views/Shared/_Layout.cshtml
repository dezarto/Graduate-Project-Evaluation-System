<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GEPS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GEPS.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navbar.css">
</head>
<body>

    <header class="customHeader">
        <div class="logoContainer">
            <img src="~/logored2.png" alt="Logo" class="logo" />
        </div>
    </header>
    <button class="toggleButton" onclick="toggleSidebar()"> <img src="~/sidebar.png" alt="sidebar" class="sidebaricon" /></button>
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div>
                <h4>Hello,</h4>
                <h3>Kullanıcı Adı</h3>
            </div>

            <button class="logout">
                <img src="~/logout.png" alt="logout" class="logouticon" />
            </button>
        </div>

        <a href="@Url.Action("TeacherApproveProject", "ProfessorController")">Teacher Approve Project</a>
        <a href="@Url.Action("TeacherEvaluateProject", "ProfessorController")">Teacher Evaluate Project</a>
        <a href="@Url.Action("TeacherViewResult", "ProfessorController")">Teacher View Result</a>
        <a href="@Url.Action("TeamHomeProfessor", "ProfessorController")">Team Home Professor</a>
        <a href="@Url.Action("ProjectCreate", "StudentController")">Project Create</a>
        <a href="@Url.Action("ProjectUpload", "StudentController")">Project Upload</a>
        <a href="@Url.Action("TeamHome", "StudentController")">Team Home</a>
    </aside>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2024 - GEPS - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<script>
    function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        sidebar.classList.toggle('open');
    }

</script>