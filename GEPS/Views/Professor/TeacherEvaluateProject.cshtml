@model ProjectTeamResponse

<html>
<head>
    <link rel="stylesheet" type="text/css" href="~/css/TeacherEvaluateProject.css">
</head>

<script>
    // Allow only numeric input
    document.addEventListener("DOMContentLoaded", () => {
        const numberInputs = document.querySelectorAll(".numberInput");

        numberInputs.forEach(input => {
            input.addEventListener("input", (event) => {
                const value = event.target.value;
                event.target.value = value.replace(/[^0-9]/g, "");
            });
        });
    });
</script>

<body>
    <div class="all-boxes">
        <div class="intro">
            <h2>Evaluate Project</h2>
            <p>Evaluate the graduate project by reviewing the team details, project description, and evaluation criteria.</p>
        </div>

        <form asp-action="PostTeacherEvaluateProject" method="post">
            <div class="box-1">
                <h4>@Model.ProjectName</h4>
                <p><strong>Description:</strong> @Model.Description</p>
                <section class="teamInfo">
                    <table class="tableOfTeamInfo">
                        <thead>
                            <tr>
                                <th>Team Name</th>
                                <th>Status</th>
                                <th>Evaluating Teacher</th>
                                <th>Team Members</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>@Model.TeamName</td>
                                <td>@(Model.isEvaluated ? "Evaluated" : "Not Evaluated")</td>
                                <td>@Model.EvaluatingTeacherFullName (@Model.EvaluatingTeacherMail)</td>
                                <td>
                                    @if (Model.Members != null && Model.Members.Any())
                                    {
                                        <ul>
                                            @foreach (var member in Model.Members)
                                            {
                                                <li>@member.StudentFullName (@member.StudentNumber)</li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <p>No members</p>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </section>
            </div>

            <div class="container">
                <div class="section">
                    <h3>Part I - Evaluation Criteria</h3>
                    @if (Model.EvaluationCriteriaDatas != null && Model.EvaluationCriteriaDatas.Any())
                    {
                        @for (int i = 0; i < Model.EvaluationCriteriaDatas.Count; i++)
                        {
                            <div class="form-group">
                                <label>
                                    <input type="checkbox" name="EvaluationCriteria[@i].IsChecked" value="true">
                                    @Model.EvaluationCriteriaDatas[i].CriteriaName (%@Model.EvaluationCriteriaDatas[i].Precent)
                                </label>
                                <input type="hidden" name="EvaluationCriteria[@i].CriteriaId" value="@Model.EvaluationCriteriaDatas[i].CriteriaId">
                                <textarea name="EvaluationCriteria[@i].Score" class="numberInput" placeholder="Enter a numeric score"></textarea>
                                <textarea name="EvaluationCriteria[@i].Comments" placeholder="Write your thoughts..."></textarea>
                            </div>
                        }
                    }
                    else
                    {
                        <p>No evaluation criteria available.</p>
                    }
                </div>

                <div class="section">
                    <h3>Part II - Checklist</h3>
                    @if (Model.ChecklistItemDatas != null && Model.ChecklistItemDatas.Any())
                    {
                        @for (int i = 0; i < Model.ChecklistItemDatas.Count; i++)
                        {
                            <div class="form-group">
                                <label>
                                    <input type="checkbox" name="ChecklistItems[@i].IsChecked" value="true">
                                    @Model.ChecklistItemDatas[i].ItemName
                                </label>
                                <input type="hidden" name="ChecklistItems[@i].ItemId" value="@Model.ChecklistItemDatas[i].ItemId">
                                <textarea name="ChecklistItems[@i].Comments" placeholder="Write your thoughts..."></textarea>
                            </div>
                        }
                    }
                    else
                    {
                        <p>No checklist items available.</p>
                    }
                </div>

                <div class="confirmation">
                    <label>
                        <input type="radio" name="Confirmation" value="true" required>
                        I confirm my evaluation results.
                    </label>
                </div>

                <input type="hidden" name="ProjectId" value="@Model.ProjectId">
                <input type="hidden" name="TeamId" value="@Model.TeamId">

                <button type="submit" class="evaluate-button">Evaluate</button>
            </div>
        </form>
    </div>
</body>
</html>
