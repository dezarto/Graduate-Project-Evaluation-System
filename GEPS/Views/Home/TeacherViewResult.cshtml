
@{
    ViewBag.Title = "TeacherViewResult";
}

@using GEPS.Models  <!-- Burada doğru namespace'i ekliyoruz -->
@model GEPS.Models.TeacherViewResultModel

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <link rel="stylesheet" type="text/css" href="~/css/TeacherViewResult.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script type="module" src="TeacherVierResult.js"></script>

    <title>TeacherViewResult</title>
</head>
<body>
    <div class="mainTeacherViewResult">
        <section class="infoTeacherViewResult">
            <h3>View Result</h3>
            <p>Create graduate project for graduation. This is a descriptive text block to navigate the student while he/she creating their team by adding team members, writing the project name and selecting the advisor for project. </p>
        </section>
        <section class="teacherSelection">
            <button class="actionButton redButton">Akhan Akbulut(Me)</button>
            <button class="actionButton redButton">Murat Taylı</button>
            <button class="actionButton redButton">Öznur Şengel</button>
            <button class="actionButton greenButton">Average Result</button>
        </section>
        <section class="resultPart">
            <div class="inlinePadding">
                <h4>AI Supported Human Resources System for IT Companies AI Supported Human Resources System for IT Companies</h4>
                <section class="teamInfo">
                    <table class="tableOfTeamInfo">
                        <thead>
                            <tr>
                                <th>
                                    <p>Team</p>
                                </th>
                                <th>
                                    <p>Status</p>
                                </th>
                                <th>
                                    <p>Evaluating Teacher</p>
                                </th>
                                <th>
                                    <p>Team Members</p>
                                </th>
                            </tr>
                        </thead>
                        <tbody id="teamTableBody">
                            <tr>
                                <td>
                                    <p> team name@*@Model.Team.TeamName*@</p>
                                </td>
                                <td>
                                    <p> status @*@Model.Team.TeamStatus*@</p>
                                </td>
                                <td>
                                    <p>advisor @*@Model.Team.AdvisorId*@</p>
                                </td>
                                <td>
                                    <p>team member1</p>
                                    @*@foreach (var member in Model.Team.TeamMemberIds)
                                    {
                                        <p>@member</p>
                                    }*@
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </section>
                <section class="resultTable">
                    <table class="tableOfResult">
                        <tr>
                            <th>
                                <p>Evaluation</p>
                            </th>
                            <th>
                                <p>Grades</p>
                            </th>
                        </tr>
                        <tr>
                            <td>
                                <p>
                                    Technical Merits (%15) <br>
                                    <b>Feedback:</b>
                                </p>
                            </td>
                            <td>
                                <p>1@*@Model.Evaluation.EvaluationScore*@</p>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <p>
                                    Project Design and Implementation (%40) <br>
                                    <b>Feedback: </b>
                                </p>
                            </td>
                            <td>
                                <p>2@*@Model.Evaluation.EvaluationScore*@</p>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <p>
                                    Report (Completeness and Content) (%15) <br>
                                    <b>Feedback:</b>
                                </p>
                            </td>
                            <td>
                                <p>@*@Model.Evaluation.EvaluationScore*@</p>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <p>
                                    Presentation (%10) <br>
                                    <b>Feedback:</b>
                                </p>
                            </td>
                            <td>
                                <p>3@*@Model.Evaluation.EvaluationScore*@</p>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <p>
                                    Demo (%10) <br>
                                    <b>Feedback:</b>
                                </p>
                            </td>
                            <td>
                                <p>7</p>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <p>
                                    Papers (%10) <br>
                                    <b>Feedback:</b>
                                </p>
                            </td>
                            <td>
                                <p>2@*@Model.Evaluation.EvaluationScore*@</p>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <p>Total Score (%100)</p>
                            </td>
                            <td>
                                <p>5@*@Model.Evaluation.EvaluationScore*@</p>
                            </td>
                        </tr>
                    </table>
                    <p><b>General Feedback</b> </p>
                </section>
            </div>
        </section>
    </div>
</body>
</html>


<script>
        document.addEventListener("DOMContentLoaded", function () {
        // Team status hücresini seç
        const teamStatusElement = document.querySelector("#teamTableBody td:nth-child(2) p");

        if (teamStatusElement) {
            const status = teamStatusElement.textContent.trim();


            switch (status) {
                case "READY TO EVALUATE":
                    teamStatusElement.style.color = "blue";
                    teamStatusElement.style.fontWeight = "bold";
                    teamStatusElement.textContent = " Ready to Evaluate";
                    break;

                case "NO RESULT":
                    teamStatusElement.style.color = "red";
                    teamStatusElement.style.fontWeight = "bold";
                    teamStatusElement.textContent = "❌ No Result";
                    break;

                case "RESULT AVAILABLE":
                    teamStatusElement.style.color = "green";
                    teamStatusElement.style.fontWeight = "bold";
                    teamStatusElement.textContent = "✅ Result Available";
                    break;

                default:
                    teamStatusElement.style.color = "black";
                    teamStatusElement.textContent = "Unknown Status";
                    break;
            }
        }
    });

    document.addEventListener("DOMContentLoaded", () => {
        // Tüm butonları seç
        const buttons = document.querySelectorAll(".actionButton");

        // Her butona tıklama olayı ekle
        buttons.forEach(button => {
            button.addEventListener("click", () => {
                // Önce tüm butonlardan 'clicked' sınıfını kaldır
                buttons.forEach(btn => btn.classList.remove("clicked"));
                // Tıklanan butona 'clicked' sınıfını ekle
                button.classList.add("clicked");
            });
        });
    });
</script>